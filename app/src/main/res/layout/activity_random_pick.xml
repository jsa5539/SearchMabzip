<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp">

    <TextView
        android:id="@+id/tv_random_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="4점 이상 랜덤 추천"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tv_random_empty"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="4점 이상 별점을 준 곳이 없습니다."
        android:textSize="16sp"
        android:visibility="gone"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_random_title"
        android:layout_marginTop="24dp" />

    <TextView
        android:id="@+id/tv_random_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="식당 이름"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_random_title"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="24dp" />

    <TextView
        android:id="@+id/tv_random_category"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="#카테고리"
        android:textSize="16sp"
        android:textColor="@android:color/darker_gray"
        app:layout_constraintStart_toStartOf="@id/tv_random_name"
        app:layout_constraintTop_toBottomOf="@id/tv_random_name"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp" />

    <TextView
        android:id="@+id/tv_random_rating"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="별점: 5/5"
        android:textSize="16sp"
        android:textColor="@android:color/holo_orange_dark"
        app:layout_constraintStart_toStartOf="@id/tv_random_name"
        app:layout_constraintTop_toBottomOf="@id/tv_random_category"
        android:layout_marginTop="8dp" />

    <Button
        android:id="@+id/btn_random_again"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="256dp"
        android:layout_marginTop="4dp"
        android:backgroundTint="#95E79F"
        android:text="다시 뽑기"
        android:textColor="@color/black"
        app:layout_constraintStart_toStartOf="@id/tv_random_name"
        app:layout_constraintTop_toBottomOf="@id/tv_random_rating" />

</androidx.constraintlayout.widget.ConstraintLayout>
